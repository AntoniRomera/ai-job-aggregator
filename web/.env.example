# Frontend environment (copy to web/.env). All optional.

# Base URL of the FastAPI backend. Default is http://localhost:8000.
VITE_API_URL=http://localhost:8000

# Force the static mock dataset instead of hitting the backend. Useful for
# previewing the UI standalone (`npm run dev` already falls back to mock data
# automatically if the backend is unreachable).
VITE_USE_MOCK=false
