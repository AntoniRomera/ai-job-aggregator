# ───────────────────────────────────────────────────────────────────────────
# AI Job Aggregator — example environment configuration
# Copy to `.env` and fill in. Everything here has a safe default, so the
# project runs fully OFFLINE (seed dataset + heuristic salary estimator) with
# no values set at all.
# ───────────────────────────────────────────────────────────────────────────

# --- LLM salary estimator -------------------------------------------------- #
# Provider selection is automatic:
#   1. ANTHROPIC_API_KEY present -> Anthropic (claude-opus-4-8) [default]
#   2. else GEMINI_API_KEY present -> Gemini (gemini-2.0-flash) [fallback]
#   3. else -> deterministic heuristic estimator (no network, always works)
#
# You can force a provider with LLM_PROVIDER = anthropic | gemini | heuristic.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=auto

# Model overrides (optional — sensible defaults baked in)
ANTHROPIC_MODEL=claude-opus-4-8
GEMINI_MODEL=gemini-2.0-flash

# --- Collection sources ---------------------------------------------------- #
# Comma-separated list of registered adapter names. "seed" is offline and is
# the default. "remoteok" opts into a live, robots-checked, rate-limited fetch.
SOURCES=seed

# --- Storage --------------------------------------------------------------- #
# SQLite by default. Swap for a Postgres URL to scale (SQLModel handles both):
#   DB_URL=postgresql+asyncpg://user:pass@host:5432/jobs
DB_URL=sqlite+aiosqlite:///collector/data/jobs.db

# --- Responsible-use / networking ------------------------------------------ #
# Minimum seconds between requests to the same domain (live adapters only).
RATE_LIMIT_SECONDS=2.0
# User-Agent advertised to remote sites and used for robots.txt checks.
USER_AGENT=ai-job-aggregator/0.1 (+https://github.com/antoniromera/ai-job-aggregator)

# --- API server ------------------------------------------------------------ #
API_HOST=0.0.0.0
API_PORT=8000
# Allowed CORS origins for the frontend (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
